{
  "name": "weather-api-typescript-mcp-tool-server",
  "version": "1.0.0",
  "description": "A TypeScript MCP tool server for exposing OpenWeatherMap city weather data to AI assistants and MCP-compatible clients.",
  "type": "module",
  "packageManager": "yarn@1.22.22",
  "bin": {
    "weather-api-mcp-server": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start:local": "node scripts/start-local.mjs",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "typescript",
    "weather",
    "weather-api"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.15.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@modelcontextprotocol/inspector": "^0.22.0",
    "@types/node": "^24.0.10",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
